# === 팀 내부 배포 ===
TEAM_ACCESS_PASSWORD=your-team-password-here
# 로컬 개발 시 인증 건너뛰기: SKIP_AUTH=true
AUTO_PAUSE_SCHEDULE=true
AUTO_PAUSE_INTERVAL_MINUTES=60

# mock = 데모 데이터 | live = 실제 API 연동
API_MODE=mock

# 자동 중단 규칙
AUTO_PAUSE_SPEND_MIN=500000
AUTO_PAUSE_ROAS_MAX=150

# --- 메타 (Facebook/Instagram) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_IDS=act_123456789,act_987654321

# --- 유튜브 (= Google Ads) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_IDS=1234567890,0987654321

# --- 틱톡 ---
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_IDS=1234567890123456789